node {
    def app

    stage('Clone') {
        checkout scm
    }

    stage('Build image') {
        app = docker.build("nassima/nginx")
    }

   docker.image('nassima/nginx').withRun('-p 8081:80') { c ->

        sh 'docker ps'

        sh '''
        for i in $(seq 1 20); do
            if curl -fs http://localhost:8081; then
                echo "NGINX OK"
                exit 0
            fi

            echo "waiting nginx..."
            sleep 2
        done

        echo "NGINX NOT READY"
        exit 1
        '''
    }
}    
