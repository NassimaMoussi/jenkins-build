node {
    def app

    stage('Clone') {
        checkout scm
    }

    stage('Build image') {
        app = docker.build("nassima/nginx")
    }

    stage('Run image') {
    	docker.image('nassima/nginx').withRun('-p 8081:80') { c ->

        	sh 'docker ps'

        	sleep 5

        	sh 'curl -f http://localhost:8081'
    }
} 
}   
