node {
    def app

    stage('Clone') {
        checkout scm
    }

    stage('Build image') {
        app = docker.build("nassima/nginx")
    }

    stage('Run image') {
    	docker.image('nassima/nginx').withRun('-p 8081:80') { c ->
        	sh 'docker ps'
        	sh 'sleep 10'
        	sh 'curl http://localhost:8081'
    }
}
      
          
         
         
        }
    

